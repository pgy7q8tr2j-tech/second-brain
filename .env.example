# ---- Database (Neon) ----
# Neon ダッシュボードの "Connection string" をそのまま貼る。
# 例: postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ---- MCP 認証トークン ----
# Claude アプリのコネクタ設定で Bearer トークンとして使う秘密の文字列。
# 推測されない長いランダム文字列にする。生成例:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_SECRET_TOKEN=
